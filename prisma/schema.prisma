generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  APPLICANT
  DONOR
  PARTNER
  REVIEWER
  ADMIN
}

enum AcademicStage {
  MEDICAL_SCHOOL
  RESIDENCY
  PHD
  POSTDOC
  OTHER
}

enum RequestType {
  EGG_FREEZING
  IVF
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_INFO
  APPROVED
  DENIED
  FUNDED
}

enum PartnerLeadType {
  INSTITUTION
  INSURER
  CLINIC
  OTHER
}

enum LeadStatus {
  NEW
  IN_REVIEW
  CONTACTED
  CLOSED
}

enum DonationStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String           @unique
  emailVerified DateTime?
  passwordHash  String?
  role          UserRole         @default(APPLICANT)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  applicantProfile ApplicantProfile?
  donations        Donation[]
  messages         Message[]
  decisions        Decision[]
  auditLogs        AuditLog[]
  partnerRequests  MeetingRequest[]

  accounts Account[]
  sessions Session[]
}

model ApplicantProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  phone          String?
  legalFirstName String?
  legalLastName  String?
  pronouns       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Application {
  id                    String            @id @default(cuid())
  applicantProfileId    String
  status                ApplicationStatus @default(DRAFT)
  requestType           RequestType?
  academicStage         AcademicStage?
  expectedCompletionAt  DateTime?
  eligibilityPassed     Boolean?
  needScore             Int?
  submittedAt           DateTime?
  assignedReviewerId    String?
  anonymizedForReview   Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  applicantProfile ApplicantProfile      @relation(fields: [applicantProfileId], references: [id], onDelete: Cascade)
  steps            ApplicationStepData[]
  documents        Document[]
  threads          MessageThread[]
  decisions        Decision[]
  award            Award?

  @@index([status])
  @@index([requestType])
  @@index([academicStage])
}

model ApplicationStepData {
  id            String   @id @default(cuid())
  applicationId String
  step          Int
  data          Json
  isComplete    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, step])
}

model Document {
  id             String   @id @default(cuid())
  applicationId  String
  type           String
  originalName   String
  mimeType       String
  byteSize       Int
  storageKey     String
  uploadStatus   String   @default("UPLOADED")
  uploadedAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model MessageThread {
  id            String   @id @default(cuid())
  applicationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([applicationId])
}

model Message {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  senderRole UserRole
  body       String
  createdAt  DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model Decision {
  id            String   @id @default(cuid())
  applicationId String
  reviewerId    String
  scoreNeed     Int?
  scoreImpact   Int?
  scoreTiming   Int?
  recommendation ApplicationStatus
  notes         String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer    User        @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Award {
  id                String   @id @default(cuid())
  applicationId     String   @unique
  amountCents       Int
  currency          String   @default("USD")
  status            String   @default("PENDING")
  disbursementNotes String?
  partnerClinicName String?
  issuedAt          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Donation {
  id              String         @id @default(cuid())
  donorId         String?
  amountCents     Int
  currency        String         @default("USD")
  status          DonationStatus @default(PENDING)
  stripeSessionId String?
  donorEmail      String?
  donorName       String?
  createdAt       DateTime       @default(now())

  donor   User?    @relation(fields: [donorId], references: [id], onDelete: SetNull)
  receipt Receipt?

  @@index([donorId])
}

model Receipt {
  id          String   @id @default(cuid())
  donationId  String   @unique
  pdfKey      String
  issuedAt    DateTime @default(now())

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
}

model PartnerLead {
  id            String          @id @default(cuid())
  orgName        String
  contactName    String
  contactEmail   String
  contactPhone   String?
  type           PartnerLeadType @default(INSTITUTION)
  notes          String?
  pilotInterest  Boolean        @default(false)
  status         LeadStatus     @default(NEW)
  createdAt      DateTime       @default(now())
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String
  fileKey     String?
  url         String?
  visibility  String   @default("PARTNER")
  createdAt   DateTime @default(now())
}

model MeetingRequest {
  id           String   @id @default(cuid())
  requesterId  String
  orgName      String
  topic        String
  notes        String?
  requestedFor DateTime?
  createdAt    DateTime @default(now())

  requester User @relation(fields: [requesterId], references: [id], onDelete: Cascade)
}

model ContactLead {
  id          String   @id @default(cuid())
  name        String
  email       String
  message     String
  subject     String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([actorId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
